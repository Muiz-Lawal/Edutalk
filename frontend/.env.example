# ============================================================================
# EduTalk Frontend - Environment Variables Configuration
# ============================================================================
#
# IMPORTANT: This is a template file. Copy to .env and fill in actual values.
#
# Copy this file:
#   cp .env.example .env
#
# ============================================================================

# ============================================================================
# 1. API CONFIGURATION
# ============================================================================
# Development
VITE_API_URL=http://localhost:5000/api
VITE_API_TIMEOUT=30000

# Production (uncomment and update)
# VITE_API_URL=https://api.edutalk.com
# VITE_API_TIMEOUT=30000

# ============================================================================
# 2. STRIPE CONFIGURATION
# ============================================================================
# Get Publishable Key from: https://dashboard.stripe.com/apikeys
# Use TEST key for development, LIVE key for production only!
#
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_TEST_PUBLISHABLE_KEY_HERE

# Production (uncomment for production)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_LIVE_KEY_HERE

# ============================================================================
# 3. PUSH NOTIFICATIONS
# ============================================================================
# Must match backend VAPID_PUBLIC_KEY
# Generate with: web-push generate-vapid-keys
#
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ============================================================================
# 4. ENVIRONMENT
# ============================================================================
VITE_ENV=development

# Production
# VITE_ENV=production

# ============================================================================
# 5. FEATURE FLAGS
# ============================================================================
VITE_ENABLE_RECORDING=true
VITE_ENABLE_LIVE_STREAMING=true
VITE_ENABLE_CHAT=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_AI_MODERATION=true

# ============================================================================
# 6. ANALYTICS
# ============================================================================
# Optional: Google Analytics, Mixpanel, etc.
#
# VITE_GA_ID=your_google_analytics_id
# VITE_MIXPANEL_TOKEN=your_mixpanel_token

# ============================================================================
# 7. THIRD-PARTY SERVICES
# ============================================================================
# Optional integrations
#
# VITE_SENTRY_DSN=your_sentry_dsn
# VITE_HOTJAR_ID=your_hotjar_id

# ============================================================================
# NOTES
# ============================================================================
# - This file IS public (frontend code is visible to users)
# - Only use PUBLIC keys here (like Stripe Publishable Key)
# - Never put SECRET keys in this file
# - Frontend .env variables must be prefixed with VITE_
# - All VITE_ variables are exposed to the browser
