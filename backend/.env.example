# ============================================================================
# EduTalk Backend - Environment Variables Configuration
# ============================================================================
# 
# IMPORTANT: This is a template file. Copy to .env and fill in actual values.
# NEVER commit the .env file to version control!
#
# Copy this file:
#   cp .env.example .env
#
# ============================================================================

# ============================================================================
# 1. SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=5000

# ============================================================================
# 2. DATABASE CONFIGURATION
# ============================================================================
# Local MongoDB (development)
MONGODB_URI=mongodb://localhost:27017/edutalk

# MongoDB Atlas (cloud) - uncomment and update
# MONGODB_URI=mongodb+srv://username:password@cluster0.abc123.mongodb.net/edutalk?retryWrites=true&w=majority

# ============================================================================
# 3. JWT AUTHENTICATION
# ============================================================================
# Generate a strong random secret:
# 
# PowerShell:
# [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((New-Guid).ToString() + (New-Guid).ToString()))
#
# Linux/Mac:
# openssl rand -base64 32
#
JWT_SECRET=your_super_secret_jwt_key_here_use_strong_random_32_chars_minimum
JWT_EXPIRE=7d

# ============================================================================
# 4. STRIPE PAYMENT INTEGRATION
# ============================================================================
# Get keys from: https://dashboard.stripe.com/apikeys
# Use TEST keys for development, LIVE keys for production only!
#
STRIPE_SECRET_KEY=sk_test_YOUR_TEST_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_TEST_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Test Card for Development:
# Card Number: 4242 4242 4242 4242
# Expiry: Any future date (e.g., 12/25)
# CVC: Any 3 digits (e.g., 123)

# ============================================================================
# 5. EMAIL SERVICE - SENDGRID (Primary)
# ============================================================================
# Get API key from: https://app.sendgrid.com/settings/api_keys
#
SENDGRID_API_KEY=your_sendgrid_api_key_here
FROM_EMAIL=noreply@edutalk.com

# ============================================================================
# 6. EMAIL SERVICE - NODEMAILER (Alternative/Fallback)
# ============================================================================
# Gmail Configuration:
# 1. Enable 2-Factor Authentication: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the generated password below (NOT your regular Gmail password)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password_here
SMTP_FROM=noreply@edutalk.com
SMTP_SECURE=false

# ============================================================================
# 7. OPENAI (Content Moderation & AI Features)
# ============================================================================
# Get API key from: https://platform.openai.com/api-keys
#
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================================================
# 8. FRONTEND & BACKEND URLS
# ============================================================================
# Development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# Production (uncomment and update)
# FRONTEND_URL=https://edutalk.com
# BACKEND_URL=https://api.edutalk.com

# ============================================================================
# 9. REDIS CACHE (Optional)
# ============================================================================
# For caching and session management
# Leave empty to disable caching
#
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# ============================================================================
# 10. LOGGING
# ============================================================================
LOG_LEVEL=debug
LOG_FILE=backend.log

# ============================================================================
# 11. RATE LIMITING
# ============================================================================
# Limit API requests to prevent abuse
#
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# 12. SESSION CONFIGURATION
# ============================================================================
SESSION_TIMEOUT=86400000

# ============================================================================
# 13. FILE UPLOADS
# ============================================================================
MAX_FILE_SIZE=52428800
UPLOAD_DIR=uploads/

# ============================================================================
# 14. SECURITY
# ============================================================================
BCRYPT_ROUNDS=10
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# 15. PUSH NOTIFICATIONS
# ============================================================================
# Generate with: web-push generate-vapid-keys
# 
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:your_email@example.com

# ============================================================================
# 16. STRIPE CONNECT (for host payouts)
# ============================================================================
# Required for connecting Stripe accounts
#
STRIPE_CONNECT_SUCCESS_URL=http://localhost:5173/dashboard/stripe/success
STRIPE_CONNECT_FAILURE_URL=http://localhost:5173/dashboard/stripe/failure

# ============================================================================
# NOTES
# ============================================================================
# - Never commit .env file to version control
# - Keep different .env files for different environments
# - Use strong, random values for all secrets
# - Rotate secrets periodically
# - Use HTTPS in production
# - Never expose secrets in logs
# - For production, increase BCRYPT_ROUNDS to 12
